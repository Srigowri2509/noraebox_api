# --- Railway ---
# When the API runs ON Railway (same project as Postgres), internal URL is fine:
# DATABASE_URL="postgresql://USER:PASSWORD@postgres.railway.internal:5432/railway"

# When you run the API on your laptop (npm run dev), .railway.internal does NOT resolve.
# In Railway → Postgres → Connect → copy the "Public Network" / TCP proxy URL instead, e.g.:
# DATABASE_URL="postgresql://USER:PASSWORD@hopper.proxy.rlwy.net:12345/railway?sslmode=require"

JWT_SECRET="change-me-to-a-long-random-string"
FRONTEND_ORIGIN="http://localhost:5173"
